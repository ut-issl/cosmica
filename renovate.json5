{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    extends: [
        "config:best-practices",
    ],
    lockFileMaintenance: {
        enabled: true,
    },
    labels: [
        "dependencies",
    ],
    minimumReleaseAge: "7 days",
    packageRules: [
        {
            matchCategories: [
                "ci",
            ],
            addLabels: [
                "ci",
            ]
        },
        {
            matchManagers: [
                "pep621",
            ],
            matchDepTypes: [
                "dependency-groups",
            ],
            addLabels: [
                "dev dependencies",
            ],
            automerge: true,
        },
    ],
}
